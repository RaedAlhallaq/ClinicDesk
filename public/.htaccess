# ============================================================
# .htaccess — جذر المشروع clinicdesk/
# الهدف: توجيه كل الطلبات لـ index.php
# ============================================================

# تفعيل محرك إعادة الكتابة
RewriteEngine On

# ------------------------------------------------------------
# الشرط الأول: الطلب ليس ملفًا حقيقيًا على الديسك
# مثال: CSS, JS, صور → تُخدَّم مباشرة بدون index.php
# ------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-f

# ------------------------------------------------------------
# الشرط الثاني: الطلب ليس مجلدًا حقيقيًا على الديسك
# ------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-d

# ------------------------------------------------------------
# القاعدة: إذا مرّ الشرطان → أعد التوجيه لـ index.php
# ^ = أي URL
# [L] = هذه آخر قاعدة، لا تكمل
# ------------------------------------------------------------
RewriteRule ^ index.php [L]